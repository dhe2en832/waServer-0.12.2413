{
  "name": "wacsa",
  "version": "0.11.0",
  "description": "Whatsapp API, Powered By CSA Computer",
  "main": "src/app.js",
  "dependencies": {
    "async-mutex": "^0.3.2",
    "cors": "^2.8.5",
    "custom-electron-titlebar": "3.2.7",
    "electron-updater": "^4.6.5",
    "express": "4.17.3",
    "express-fileupload": "1.3.1",
    "express-validator": "6.14.0",
    "ini": "^2.0.0",
    "node-fetch": "2.6.7",
    "qrcode": "1.5.0",
    "whatsapp-web.js": "1.17.0"
  },
  "devDependencies": {
    "electron": "12.2.2",
    "electron-builder": "22.11.3"
  },
  "scripts": {
    "start": "electron .",
    "copy": "cp ./environment/ChromeSetup.exe dist/",
    "build-clean": "rm -rf dist_backup && mv dist dist_backup && electron-builder && npm run copy",
    "build": "electron-builder && npm run copy"
  },
  "author": "CSA Computer",
  "license": "MIT",
  "keywords": [
    "whatsapp-web.js",
    "electron.js",
    "csacomputer.com"
  ],
  "build": {
    "asar": true,
    "appId": "com.csacomputer.wacsa",
    "copyright": "Copyright © 2022 CSA Computer x Whatsapp",
    "productName": "wacsa",
    "win": {
      "target": "nsis",
      "icon": "src/images/icon.ico"
    },
    "nsis": {
      "installerIcon": "src/images/icon.ico",
      "uninstallerIcon": "src/images/uninstaller-icon.ico",
      "deleteAppDataOnUninstall": true,
      "menuCategory": true,
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "include": "./installer.nsh"
    },
    "files": [
      "!**/.vscode/*",
      "!**/backup/*",
      "!**/dist_backup/*",
      "!**/docs/*",
      "!**/environment/*",
      "!**/node_modules/*",
      "!**/session/*",
      "!.gitignore",
      "!installer.nsh",
      "!readme.md",
      "!wacsa-error.log",
      "!wacsa-received.json",
      "!wacsa-sent.json",
      "!wacsa-session.json",
      "!wacsa-statistic.json"
    ],
    "extraFiles": [
      {
        "from": "./wacsa.ini",
        "to": "."
      },
      {
        "from": "./wacsa.ini",
        "to": "./backup_wacsa.ini"
      },
      {
        "from": "./environment/backup",
        "to": "backup"
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "http://csa1.completeselular.com:2080/wacsa-updater"
      }
    ]
  }
}
