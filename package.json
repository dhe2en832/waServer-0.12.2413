{
  "name": "wacsa",
  "version": "0.9.2",
  "description": "Whatsapp API Powered By CSA Computer",
  "main": "main.js",
  "dependencies": {
    "async-mutex": "^0.2.6",
    "cors": "^2.8.5",
    "custom-electron-titlebar": "^3.2.7",
    "express": "^4.17.1",
    "express-fileupload": "^1.2.1",
    "express-validator": "^6.11.1",
    "ini": "^1.3.5",
    "jquery": "^3.6.0",
    "node-fetch": "^2.6.1",
    "qrcode": "^1.4.4",
    "socket.io": "^2.4.1",
    "whatsapp-web.js": "^1.14.0"
  },
  "devDependencies": {
    "electron": "^12.0.10",
    "electron-builder": "22.10.5"
  },
  "scripts": {
    "start": "electron .",
    "copy": "cp ChromeSetup.exe dist/ && cp readme.txt dist/",
    "build": "rm -rf dist && electron-builder && npm run copy"
  },
  "author": "CSA Computer",
  "license": "MIT",
  "keywords": [
    "whatsapp-web.js",
    "electron.js",
    "csa-computer"
  ],
  "build": {
    "asar": false,
    "appId": "id.csacomputer.wacsa",
    "copyright": "Copyright © 2021 CSA Computer x Whatsapp",
    "productName": "wacsa",
    "win": {
      "target": "nsis",
      "icon": "images/icon.ico"
    },
    "nsis": {
      "installerIcon": "images/icon.ico",
      "uninstallerIcon": "images/uninstaller-icon.ico",
      "deleteAppDataOnUninstall": true,
      "menuCategory": true,
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "include": "./installer.nsh"
    },
    "files": [
      "!ChromeSetup.exe",
      "!backup_wacsa_old.ini",
      "!installer.nsh",
      "!.env",
      "!.gitignore",
      "!readme.txt",
      "!**/.vscode/*"
    ],
    "extraFiles": [
      {
        "from": "./wacsa.ini",
        "to": "."
      },
      {
        "from": "./backup_wacsa.ini",
        "to": "."
      },
      "backup"
    ]
  }
}
